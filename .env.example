# ── Backend URL ──────────────────────────────────────────────────────────────
#
# Dejar vacío cuando frontend y backend corren en el mismo servidor (Next.js default).
# Todas las llamadas irán a /api/... del mismo origen.
#
# Cuando se separen frontend y backend, apuntar aquí al servidor del backend:
# NEXT_PUBLIC_API_URL=https://api.totalplay.internal
#
NEXT_PUBLIC_API_URL=

# MariaDB (WAMP local usa puerto 3307)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=inge
DB_PASSWORD=inge_dev
DB_NAME=ingenierias
DATABASE_URL=mysql://inge:inge_dev@127.0.0.1:3307/ingenierias

# ── Base de datos (legacy / Prisma) ───────────────────────────────────────────
# Descomentar cuando esté disponible la BD
#
# PostgreSQL:
# DATABASE_URL="postgresql://usuario:password@host:5432/ingenierias"
#
# MariaDB:
# DATABASE_URL="mysql://usuario:password@host:3306/ingenierias"

# DATABASE_URL=

# ── Servicios externos ────────────────────────────────────────────────────────
# Completar cuando Totalplay provea los endpoints
#
DISCOVERY_BASE_URL=
DISCOVERY_API_KEY=

CMDB_BASE_URL=
CMDB_API_KEY=

SMC_BASE_URL=

# ── Auth / SSO ────────────────────────────────────────────────────────────────
# Proveedor activo: local | ldap | oauth | sso (solo local implementado hoy)
AUTH_PROVIDER=local
AUTH_SESSION_HOURS=12

# ── Integración salida (ingenierías Aprobada → sistema RFC / Neo4j) ───────────
INTEGRACION_API_KEY=
INTEGRACION_WEBHOOK_URL=
# URL pública de esta app (para vistaUrl absoluta en el payload)
NEXT_PUBLIC_APP_URL=http://localhost:6001

# ── Integración entrada (WS externo: ingenierías ya aprovisionadas) ───────────
# Pendiente de spec Totalplay. Cuando exista:
# APROVISIONAMIENTO_WS_URL=https://otro-sistema/.../aprovisionadas
# APROVISIONAMIENTO_API_KEY=
APROVISIONAMIENTO_WS_URL=
APROVISIONAMIENTO_API_KEY=

LDAP_URL=
LDAP_BASE_DN=
LDAP_BIND_USER=
LDAP_BIND_PASSWORD=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
